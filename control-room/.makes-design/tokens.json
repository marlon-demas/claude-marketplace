{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "surface": "agent-system-guide",
    "direction": "Control Room Live",
    "authored": "2026-06-11",
    "source": "index.html :root block + component CSS"
  },
  "color": {
    "bg": {
      "$value": "#0B0E15",
      "$type": "color",
      "$description": "Page background — deepest deep-space surface"
    },
    "bg-2": {
      "$value": "#0F131D",
      "$type": "color",
      "$description": "Secondary background (simulator shell, bg-2 panels)"
    },
    "surface": {
      "$value": "#141927",
      "$type": "color",
      "$description": "Card / panel background"
    },
    "surface-2": {
      "$value": "#1A2032",
      "$type": "color",
      "$description": "Elevated surface — dialogs, rail dots background"
    },
    "line": {
      "$value": "rgba(148,170,220,0.13)",
      "$type": "color",
      "$description": "Hairline rule, default card border"
    },
    "line-2": {
      "$value": "rgba(148,170,220,0.22)",
      "$type": "color",
      "$description": "Stronger border — hover / focus context"
    },
    "text": {
      "$value": "#E8EDF8",
      "$type": "color",
      "$description": "Body text, headings — 14.1:1 on bg, 12.9:1 on surface"
    },
    "text-dim": {
      "$value": "#8B96B0",
      "$type": "color",
      "$description": "Secondary text, labels, descriptors — 5.5:1 on bg, 5.0:1 on surface. AA at all sizes."
    },
    "text-faint": {
      "$value": "#5A6480",
      "$type": "color",
      "$description": "DECORATIVE/ARIA-HIDDEN labels only. 2.9:1 on bg. Never informational content — see tokens.md for rule and fix history."
    },
    "pulse": {
      "$value": "#6CA8FF",
      "$type": "color",
      "$description": "Brand accent — eyebrows, rail progress, focus ring, dispatch arrows. 8.68:1 on bg."
    },
    "pulse-bright": {
      "$value": "#A7CBFF",
      "$type": "color",
      "$description": "Elevated pulse — dispatch line text, hover highlights"
    },
    "tier": {
      "haiku": {
        "$value": "#4ADE9C",
        "$type": "color",
        "$description": "Haiku tier data encoding — SVG dot, pill, card hover bar. ~8.1:1 on surface. NEVER decorative."
      },
      "sonnet": {
        "$value": "#6CA8FF",
        "$type": "color",
        "$description": "Sonnet tier data encoding. Same hex as pulse but distinct token, distinct role. NEVER decorative."
      },
      "opus": {
        "$value": "#C08BFF",
        "$type": "color",
        "$description": "Opus tier data encoding. ~6.0:1 on surface. NEVER decorative."
      },
      "fable": {
        "$value": "#FFB35C",
        "$type": "color",
        "$description": "Fable tier data encoding. ~6.5:1 on surface. Also used for no-match lesson accent and dlg-special note. NEVER decorative."
      }
    },
    "danger": {
      "$value": "#FF7A6C",
      "$type": "color",
      "$description": "Sentinel special-note border/bg tint, feed live-dot (aria-hidden). Distinct from tier hues."
    }
  },
  "font": {
    "display": {
      "$value": "'Schibsted Grotesk', system-ui, -apple-system, sans-serif",
      "$type": "fontFamily",
      "$description": "Variable 400–900. Base64-inlined woff2, Latin subset. Zero CDN requests."
    },
    "mono": {
      "$value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace",
      "$type": "fontFamily",
      "$description": "Variable 400–500. Base64-inlined woff2, Latin subset. Dispatch lines, tier pills, eyebrows, simulator."
    }
  },
  "fontSize": {
    "heroH1": { "$value": "clamp(44px, 4.6vw, 68px)", "$type": "dimension" },
    "sectionH2": { "$value": "clamp(32px, 3.2vw, 46px)", "$type": "dimension" },
    "stageH3": { "$value": "20px", "$type": "dimension" },
    "groupH3": { "$value": "22px", "$type": "dimension" },
    "bodyBase": { "$value": "17px", "$type": "dimension" },
    "bodyLarge": { "$value": "18px", "$type": "dimension" },
    "bodySmall": { "$value": "15px", "$type": "dimension" },
    "monoEyebrow": { "$value": "12px", "$type": "dimension" },
    "monoLabel": { "$value": "11px", "$type": "dimension" },
    "monoDispatch": { "$value": "clamp(16px, 1.8vw, 22px)", "$type": "dimension" },
    "tierPill": { "$value": "11px", "$type": "dimension" },
    "dialogName": { "$value": "26px", "$type": "dimension" },
    "footer": { "$value": "12.5px", "$type": "dimension" }
  },
  "fontWeight": {
    "regular": { "$value": "400", "$type": "fontWeight" },
    "medium": { "$value": "500", "$type": "fontWeight" },
    "semibold": { "$value": "600", "$type": "fontWeight" },
    "bold": { "$value": "700", "$type": "fontWeight" },
    "extrabold": { "$value": "800", "$type": "fontWeight" }
  },
  "borderRadius": {
    "agentCard": { "$value": "12px", "$type": "dimension" },
    "stageCard": { "$value": "14px", "$type": "dimension" },
    "dialog": { "$value": "16px", "$type": "dimension" },
    "simShell": { "$value": "18px", "$type": "dimension" },
    "button": { "$value": "8px", "$type": "dimension" },
    "tierPill": { "$value": "99px", "$type": "dimension" },
    "dispatchBlock": { "$value": "9px", "$type": "dimension" },
    "sentinelAside": { "$value": "14px", "$type": "dimension" }
  },
  "shadow": {
    "agentCardHover": {
      "$value": "0 14px 34px rgba(0,0,0,0.45), 0 0 20px color-mix(in srgb, var(--tier-color) 12%, transparent)",
      "$type": "shadow"
    },
    "stageHover": {
      "$value": "0 12px 40px rgba(0,0,0,0.4), 0 0 24px rgba(108,168,255,0.08)",
      "$type": "shadow"
    },
    "dialog": {
      "$value": "0 32px 90px rgba(0,0,0,0.7)",
      "$type": "shadow"
    },
    "focusRing": {
      "$value": "0 0 0 2px var(--bg), 0 0 0 4px var(--pulse)",
      "$type": "shadow",
      "$description": "Two-ring focus indicator — inner gap matches bg, outer ring is pulse blue"
    },
    "buttonPrimaryHover": {
      "$value": "0 4px 28px rgba(108,168,255,0.45)",
      "$type": "shadow"
    },
    "dispatchLineShown": {
      "$value": "0 0 32px rgba(108,168,255,0.15)",
      "$type": "shadow"
    }
  },
  "duration": {
    "ambientFeedBase": {
      "$value": "2200ms",
      "$type": "duration",
      "$description": "Base interval; jitter adds 0–800ms per step (2200–3000ms range)"
    },
    "feedLineAnimate": { "$value": "500ms", "$type": "duration" },
    "dialogIn": {
      "$value": "320ms",
      "$type": "duration",
      "$description": "dialogIn keyframe — scale-settle easing cubic-bezier(0.2,0.9,0.3,1.2)"
    },
    "sectionReveal": { "$value": "700ms", "$type": "duration" },
    "sectionRevealStagger": { "$value": "600ms", "$type": "duration" },
    "traceRowReveal": { "$value": "450ms", "$type": "duration" },
    "railProgress": { "$value": "600ms", "$type": "duration" },
    "railDotLight": { "$value": "350ms", "$type": "duration" },
    "dispatchLineAppear": { "$value": "500ms", "$type": "duration" },
    "hoverCard": { "$value": "220ms", "$type": "duration" },
    "hoverButton": { "$value": "180ms", "$type": "duration" },
    "noMatchLesson": { "$value": "400ms", "$type": "duration" }
  },
  "easing": {
    "settle": {
      "$value": "cubic-bezier(0.2,0.6,0.2,1)",
      "$type": "cubicBezier",
      "$description": "Standard motion easing — reveal, feed, card hover"
    },
    "dialogSettle": {
      "$value": "cubic-bezier(0.2,0.9,0.3,1.2)",
      "$type": "cubicBezier",
      "$description": "Slight overshoot settle — dialog open, dispatch line appear"
    },
    "railSettle": {
      "$value": "cubic-bezier(0.2,0.9,0.3,1.3)",
      "$type": "cubicBezier",
      "$description": "Rail dot scale — stronger overshoot for tactile pop"
    },
    "railProgress": {
      "$value": "cubic-bezier(0.4,0,0.2,1)",
      "$type": "cubicBezier",
      "$description": "Material standard — rail progress bar"
    }
  }
}
